rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Team Logos ───────────────────────────────────────
    // Any signed-in user can read logos
    // Any signed-in user can upload (max 5MB, images only)
    match /team-logos/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Team Resources (documents) ──────────────────────
    // Any signed-in user can read team resources
    // Any signed-in user can upload (max 25MB)
    // Any signed-in user can delete
    match /team-resources/{teamId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 25 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // ─── User Avatars ────────────────────────────────────
    // Anyone signed in can read avatars
    // Users can only write their own avatar (max 5MB, images only)
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ─── Deny everything else ────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
